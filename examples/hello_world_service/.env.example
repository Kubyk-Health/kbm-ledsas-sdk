# LEDSAS service identity. MUST match ServiceApp(service_name=...) in
# main.py — the sender computes the command exchange from this value.
KBM_LEDSAS_SERVICE_NAME=hello-world
# Optional tenant. Leave unset/blank for the simple single-tenant exchange
# cmd.hello-world.v1; setting it changes the exchange to
# cmd.<tenant>.hello-world.v1 (service and sender must agree).
#KBM_LEDSAS_TENANT=

# Connection settings.
# Defaults match deploy/local/docker-compose.yml (RabbitMQ + Azurite on
# loopback). NOTE the connection strings are QUOTED — they contain ';'
# which a shell would otherwise split on. (The SDK strips a matched pair of
# surrounding quotes, so the same quoted value also works with
# `docker run --env-file`.)
KBM_LEDSAS_RABBITMQ_URL="amqp://guest:guest@127.0.0.1:5672/"
KBM_LEDSAS_BLOB_CONN_STRING="DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;"

# Default blob container (unused by this hello-world handler, but the SDK
# requires blob configuration at startup; the Azurite default above is fine).
KBM_LEDSAS_CONTAINER=hello-world

# Logging
KBM_LEDSAS_LOG_LEVEL=INFO
KBM_LEDSAS_LOG_FORMAT=json

# Health probe binding (defaults shown). For pod deployments where the
# orchestrator probes from outside the container network namespace, bind
# 0.0.0.0 instead of 127.0.0.1.
KBM_LEDSAS_HEALTH_HOST=127.0.0.1
KBM_LEDSAS_HEALTH_PORT=8090
